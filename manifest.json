{
  "manifest_version": 3,
  "name": "OpenFront Auto-Join & Helpers",
  "version": "1.5.0",
  "description": "Automatically joins OpenFront lobbies when they match your selected criteria.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://openfront.io/*"
  ],
  "action": {
    "default_title": "OpenFront Auto-Join & Helpers",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://openfront.io/*"
      ],
      "js": [
        "map-data.js",
        "shared/settings.js",
        "content/core.js",
        "content/floating-helpers.js",
        "content/auto-join.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge/runtime.js",
        "page-bridge/shared-utils.js",
        "page-bridge/selective-trade-policy.js",
        "page-bridge/alliances.js",
        "page-bridge/bot-markers.js",
        "page-bridge/gold-per-minute.js",
        "page-bridge/trade-balances.js",
        "page-bridge/attack-amounts.js",
        "page-bridge/heatmaps.js",
        "page-bridge/bootstrap.js",
        "assets/autojoin.wav"
      ],
      "matches": [
        "https://openfront.io/*"
      ]
    }
  ]
}
